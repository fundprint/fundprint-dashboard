# The dashboard reads a static, version-pinned snapshot committed at
# data/snapshot.json. It has no runtime database connection and no secrets.
#
# The snapshot is generated in the fundprint-data repo:
#   python scripts/export_dashboard_snapshot.py --out ../fundprint-dashboard/data/snapshot.json
#
# Optional: privacy-respecting analytics domain (Plausible). Leave unset to
# disable analytics entirely.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
